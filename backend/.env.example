# ── Copy this file to `.env` and fill in real values. NEVER commit `.env`. ──

# Runtime
NODE_ENV=development
PORT=5000

# Where the static site lives (served by this backend). Relative to backend/.
FRONTEND_DIR=../frontend

# Comma-separated list of allowed browser origins for the API (CORS).
# Same-origin (backend serves the site) needs nothing here.
# For a separately-served frontend (e.g. http://localhost:8000) add it:
CORS_ORIGINS=http://localhost:8000,http://localhost:5000

# Trust the first proxy hop (set to 1 behind nginx/Heroku/Render so rate-limit
# and secure cookies see the real client IP). Leave 0 for local/no proxy.
TRUST_PROXY=0

# ── Lead notifications (optional). If SMTP_HOST is empty, leads are still saved
#    to backend/data/leads.jsonl and logged; email is simply skipped. ──
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="CloudPi <no-reply@cloudpi.ai>"
LEADS_NOTIFY_TO=sales@cloudpi.ai
